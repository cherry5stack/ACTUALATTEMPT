						<bool name="DefinesCapabilities">true</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">ConfigHandler</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">15eeaabac4e740740a3ca8a0000102a5</UniqueId>
